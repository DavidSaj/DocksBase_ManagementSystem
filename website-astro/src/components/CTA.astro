---
import styles from './CTA.module.css'
import { getStrings, type LangCode } from '../i18n/strings'

interface Props { lang: LangCode }
const { lang } = Astro.props
const t = getStrings(lang)
---
<section class={styles.section}>
  <div class={styles.inner}>
    <div class={styles.anchorDivider}>
      <div class={styles.line} />
      <svg width="22" height="26" viewBox="0 0 24 28" fill="none" stroke="#0c1f3d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.2">
        <circle cx="12" cy="4" r="3"/><line x1="12" y1="7" x2="12" y2="26"/>
        <line x1="4" y1="13" x2="20" y2="13"/>
        <path d="M4 13 Q2 20 6 24"/><path d="M20 13 Q22 20 18 24"/>
        <path d="M6 24 Q12 27 18 24"/>
      </svg>
      <div class={styles.line} />
    </div>
    <h2 class={styles.title}>
      {t.cta.title1}{t.cta.titleEm && <><br /><em>{t.cta.titleEm}</em></>}
    </h2>
    <p class={styles.sub}>{t.cta.sub}</p>
    <div class={styles.actions}>
      <a href="#" class={`${styles.btn} ${styles.btnPrimary}`}>{t.cta.btn1}</a>
      <a href="#" class={`${styles.btn} ${styles.btnSecondary}`}>{t.cta.btn2}</a>
    </div>
    <p class={styles.note}>{t.cta.note}</p>
  </div>
</section>
