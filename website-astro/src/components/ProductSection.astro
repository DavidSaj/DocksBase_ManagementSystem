---
import styles from './ProductSection.module.css'
import { getStrings, type LangCode } from '../i18n/strings'

interface Props { lang: LangCode }
const { lang } = Astro.props
const t = getStrings(lang)
---
<section class={styles.section} id="product">
  <div class={styles.inner}>
    <div class={styles.layout} data-product-layout>
      <div class={styles.text}>
        <div class={styles.eyebrow}>{t.product.eyebrow}</div>
        <h2 class={styles.title}>{t.product.title}</h2>
        <p class={styles.sub}>{t.product.sub}</p>
        <div style="margin-top:32px;display:flex;gap:10px;flex-wrap:wrap">
          <button class={styles.demoBtn}>{t.product.demo}</button>
        </div>
      </div>
      <div class={styles.screenshot}>
        <img
          src="/images/app-overview.png"
          alt={t.product.alt}
          class={styles.img}
        />
      </div>
    </div>
  </div>
</section>

<script define:vars={{ textCls: styles.text, textVisibleCls: styles.textVisible, shotCls: styles.screenshot, shotVisibleCls: styles.shotVisible }}>
  document.querySelectorAll('[data-product-layout]').forEach(layout => {
    const obs = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        layout.querySelector('.' + textCls)?.classList.add(textVisibleCls)
        setTimeout(() => layout.querySelector('.' + shotCls)?.classList.add(shotVisibleCls), 150)
        obs.unobserve(layout)
      }
    }, { threshold: 0.1 })
    obs.observe(layout)
  })
</script>
