---
import styles from './TrustBar.module.css'
import { getStrings, type LangCode } from '../i18n/strings'

interface Props { lang: LangCode }
const { lang } = Astro.props
const t = getStrings(lang)

const marinas = ['Harwich Marina', 'Port Vauban', 'Gibraltar Yacht Marina', 'Zea Marina', 'Royal Harbour', 'Palma de Mallorca']
---
<div class={styles.bar}>
  <span class={styles.label}>{t.trustLabel}</span>
  <div class={styles.names}>
    {marinas.map((name, i) => (
      <span style="display:flex;align-items:center;gap:36px">
        <span class={styles.name}>{name}</span>
        {i < marinas.length - 1 && <span class={styles.dot} />}
      </span>
    ))}
  </div>
</div>
