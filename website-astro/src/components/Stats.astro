---
import styles from './Stats.module.css'
import { getStrings, type LangCode } from '../i18n/strings'

interface Props { lang: LangCode }
const { lang } = Astro.props
const t = getStrings(lang)

const stats = [
  { num: '20', suffix: '', desc: t.stats.descs[0] },
  { num: '30', suffix: t.stats.suffixDay, desc: t.stats.descs[1] },
  { num: '99', suffix: '.9%', desc: t.stats.descs[2] },
  { num: '4', suffix: t.stats.suffixHrs, desc: t.stats.descs[3] },
]
---
<section class={styles.section}>
  <div class={styles.grid} data-stats-grid>
    {stats.map(s => (
      <div class={styles.item}>
        <div class={styles.num}>{s.num}<span>{s.suffix}</span></div>
        <div class={styles.desc}>{s.desc}</div>
      </div>
    ))}
  </div>
</section>

<script define:vars={{ itemCls: styles.item, visibleCls: styles.itemVisible }}>
  document.querySelectorAll('[data-stats-grid]').forEach(grid => {
    const obs = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        grid.querySelectorAll('.' + itemCls).forEach((item, i) =>
          setTimeout(() => item.classList.add(visibleCls), i * 100)
        )
        obs.unobserve(grid)
      }
    }, { threshold: 0.2 })
    obs.observe(grid)
  })
</script>
