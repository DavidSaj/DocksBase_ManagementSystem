---
import styles from './Pricing.module.css'
import { getStrings, type LangCode } from '../i18n/strings'

interface Props { lang: LangCode }
const { lang } = Astro.props
const t = getStrings(lang)

// Prices stay in EUR and are not localized
const prices = ['€149', '€349', '€899']
const per = '/ month'
const perByLang: Record<string, string> = {
  en: '/ month', de: '/ Monat', nl: '/ maand', it: '/ mese',
  es: '/ mes', fr: '/ mois', el: '/ μήνα',
}
const perLabel = perByLang[lang] ?? per

const plans = t.pricing.plans.map((p, i) => ({
  ...p,
  price: prices[i],
  per: perLabel,
  featured: i === 1,
}))
---
<section class={styles.section} id="pricing">
  <div class={styles.inner}>
    <div class={styles.header}>
      <div class={styles.eyebrow}>{t.pricing.eyebrow}</div>
      <h2 class={styles.title}>{t.pricing.title}</h2>
      <p class={styles.sub}>{t.pricing.sub}</p>
    </div>
    <div class={styles.grid}>
      {plans.map(plan => (
        <div class={`${styles.card} ${plan.featured ? styles.featured : ''}`}>
          <div class={styles.tier}>{plan.tier}</div>
          <div class={styles.name}>{plan.name}</div>
          <div class={styles.desc}>{plan.desc}</div>
          <div class={styles.priceRow}>
            <div class={styles.amount}>{plan.price}</div>
            {plan.per && <div class={styles.per}>{plan.per}</div>}
          </div>
          <div class={styles.berths}>{plan.berths}</div>
          <ul class={styles.features}>
            {plan.features.map(f => (
              <li>
                <div class={`${styles.check} ${plan.featured ? styles.checkFeatured : ''}`}>
                  <svg viewBox="0 0 12 12" fill="none" stroke={plan.featured ? '#d4b07a' : '#0c1f3d'} stroke-width="2.5">
                    <polyline points="2,6 5,9 10,3"/>
                  </svg>
                </div>
                {f}
              </li>
            ))}
          </ul>
          <a href="/signup" class={`${styles.btn} ${plan.featured ? styles.btnFeatured : styles.btnOutline}`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
    <p class={styles.note}>{t.pricing.note}</p>
  </div>
</section>
