---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav'
import Hero from '../../components/Hero.astro'
import TrustBar from '../../components/TrustBar.astro'
import Features from '../../components/Features'
import Stats from '../../components/Stats.astro'
import ProductSection from '../../components/ProductSection.astro'
import SplitSection from '../../components/SplitSection.astro'
import WhiteLabel from '../../components/WhiteLabel.astro'
import MobileApp from '../../components/MobileApp.astro'
import Pricing from '../../components/Pricing.astro'
import Faq from '../../components/Faq'
import FeatureRequest from '../../components/FeatureRequest'
import CTA from '../../components/CTA.astro'
import Footer from '../../components/Footer.astro'
import { LANGUAGES, getStrings, type LangCode } from '../../i18n/strings'

export function getStaticPaths() {
  return LANGUAGES.map(({ code }) => ({ params: { lang: code } }))
}

const { lang } = Astro.params as { lang: LangCode }
const t = getStrings(lang)
---
<Base lang={lang}>
  <Nav lang={lang} t={t} client:load />
  <Hero t={t} />
  <TrustBar lang={lang} />
  <Features t={t} client:visible />
  <Stats lang={lang} />
  <ProductSection lang={lang} />

  <SplitSection
    eyebrow={t.splits.integrate.eyebrow}
    title={t.splits.integrate.title}
    body={t.splits.integrate.body}
    checklist={t.splits.integrate.checklist}
    cta={t.splits.integrate.cta}
    image="/images/marina-aerial-close.jpg"
    alt={t.splits.integrate.alt}
  />
  <SplitSection
    eyebrow={t.splits.workflow.eyebrow}
    title={t.splits.workflow.title}
    body={t.splits.workflow.body}
    checklist={t.splits.workflow.checklist}
    cta={t.splits.workflow.cta}
    image="/images/marina-sailboats.jpg"
    alt={t.splits.workflow.alt}
    reverse={true}
    cream={true}
  />
  <SplitSection
    eyebrow={t.splits.platform.eyebrow}
    title={t.splits.platform.title}
    body={t.splits.platform.body}
    checklist={t.splits.platform.checklist}
    cta={t.splits.platform.cta}
    image="/images/marina-dock-boats.jpg"
    alt={t.splits.platform.alt}
  />

  <div class="sr"><WhiteLabel t={t} /></div>
  <MobileApp lang={lang} />
  <div class="sr"><Pricing lang={lang} /></div>
  <div class="sr"><Faq t={t} client:load /></div>
  <div class="sr"><FeatureRequest t={t} client:load /></div>
  <div class="sr"><CTA lang={lang} /></div>
  <Footer lang={lang} />
</Base>
