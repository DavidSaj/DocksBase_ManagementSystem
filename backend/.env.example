# Dropbox Sign (HelloSign)
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=
DROPBOX_SIGN_WEBHOOK_SECRET=

# Resend (email)
RESEND_API_KEY=

# Database (required for Celery workers — SQLite does NOT work with concurrent workers)
DATABASE_URL=postgresql://user:password@localhost/docksbase

# Redis
REDIS_URL=redis://localhost:6379/0
